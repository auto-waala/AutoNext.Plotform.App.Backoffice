{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "accesscontrol-cluster": {
        "LoadBalancingPolicy": "PowerOfTwoChoices",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "RevolutionDuration": "00:02:00"
          }
        },
        "HttpClient": {
          "Timeout": "00:01:30",
          "MaxConnectionsPerServer": 100
        },
        "Destinations": {
          "accesscontrol-prod-1": {
            "Address": "https://autonext-accesscontrole-prod.services.azurewebsites.betalen.in"
          }
        }
      },
      "core-cluster": {
        "LoadBalancingPolicy": "PowerOfTwoChoices",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "RevolutionDuration": "00:02:00"
          }
        },
        "HttpClient": {
          "Timeout": "00:01:30",
          "MaxConnectionsPerServer": 100
        },
        "Destinations": {
          "core-prod-1": {
            "Address": "https://autonext-core-prod.services.azurewebsites.betalen.in"
          },
          "core-prod-2": {
            "Address": "https://autonext-core-prod-2.services.azurewebsites.betalen.in"
          }
        }
      }
    }
  }
}