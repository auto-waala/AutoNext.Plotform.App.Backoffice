        "ClusterId": "accesscontrol-cluster",
        "Match": {
          "Path": "/health/accesscontrol/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/health/accesscontrol" }
        ]
      },
      "swagger-accesscontrol": {
        "ClusterId": "accesscontrol-cluster",
        "Match": {
          "Path": "/swagger/accesscontrol/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/swagger/accesscontrol" }
        ]
      },

      "core-brands": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/v{version}/Brands/{**catch-all}"
        },
        "Transforms": [
