{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "accesscontrol-auth": {
        "ClusterId": "accesscontrol-cluster",
        "Match": {
          "Path": "/api/v{version}/Auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v{version}/Auth/{**catch-all}" }
        ]
      },
      "accesscontrol-organizations": {
        "ClusterId": "accesscontrol-cluster",
        "Match": {
          "Path": "/api/v{version}/Organizations/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v{version}/Organizations/{**catch-all}" }
        ]
      },
      "accesscontrol-permissions": {
        "ClusterId": "accesscontrol-cluster",
        "Match": {
          "Path": "/api/v{version}/Permissions/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v{version}/Permissions/{**catch-all}" }
        ]
      },
      "accesscontrol-roles": {
        "ClusterId": "accesscontrol-cluster",
