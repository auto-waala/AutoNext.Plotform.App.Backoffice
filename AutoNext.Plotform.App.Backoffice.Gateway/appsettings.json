        "Match": {
          "Path": "/api/v{version}/DocumentTypes/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v{version}/DocumentTypes/{**catch-all}" }
        ]
      },
      "core-features": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/v{version}/features/{**catch-all}"
