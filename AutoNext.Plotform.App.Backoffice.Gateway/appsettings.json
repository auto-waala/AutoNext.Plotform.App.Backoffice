      "core-health": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/health/core/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/health/core" }
        ]
      },
      "swagger-core": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/swagger/core/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/swagger/core" }
        ]
      }
    },
    "Clusters": {
      "accesscontrol-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "RevolutionDuration": "00:01:00"
          }
        },
        "HttpClient": {
          "Timeout": "00:01:00"
        },
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7056"
          }
        }
      },
      "core-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "HttpClient": {
          "Timeout": "00:01:00"
        },
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7231"
          }
        }
      }
    }
  }
