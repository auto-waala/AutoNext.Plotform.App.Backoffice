@page "/brands"
@inherits BrandsBase
@using BlazorBootstrap

<div class="dashboard">
    <!-- Welcome Header -->
    <div class="dashboard-header">
        <div>
            <h1 class="dashboard-title">Brands</h1>
            <p class="dashboard-subtitle">Manage all your brands with advanced search, filter & sort</p>
        </div>
        <div class="date-badge">
            <i class="bi bi-calendar"></i>
            <span>@DateTime.Now.ToString("MMMM dd, yyyy")</span>
        </div>
    </div>

    <!-- Brands Table Card -->
    <div class="table-card">
        <div class="table-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">Brands Directory (@TotalCount total)</h5>
                <small class="text-muted">Page @CurrentPage of @(Math.Ceiling((double)TotalCount / ItemsPerPage))</small>
            </div>
            <div class="d-flex gap-2">
                <Button Size="ButtonSize.Small" Clicked="CreateNewBrand">
                    <Icon Name="IconName.Plus" /> New Brand
                </Button>
            </div>
        </div>

        <div class="table-responsive">
            <DataGrid TItem="Brand"
                      Data="@Brands"
                      TotalItems="@TotalCount"
                      ItemsPerPage="ItemsPerPage"
                      CurrentPage="@CurrentPage"
                      ShowPager="true"
                      PageSizeOptions="@PageSizeOptions"
                      Virtualize="true"
                      Responsive="true"
                      Striped="true"
                      Hoverable="true"
                      Sortable="true"
                      Filterable="true"
                      ShowFilterRow="true"
                      SelectionMode="DataGridSelectionMode.Multiple"
                      SelectedItems="@SelectedBrands"
                      TableClasses="data-table dashboard-table"
                      PagerPosition="PagerPosition.Bottom">

                <LoadingTemplate>
                    <div class="text-center py-4">
                        <Spinner Type="SpinnerType.Border" Color="SpinnerColor.Primary" />
                        <p class="mt-2 text-muted small">Loading brands...</p>
                    </div>
                </LoadingTemplate>

                <DataGridColumns>
                    @* ... your columns ... *@
                </DataGridColumns>

                <EmptyTemplate>
                    @* ... your empty state ... *@
                </EmptyTemplate>

            </DataGrid>
        </div>
    </div>
</div>