@page "/brands"
@inherits BrandsBase
@using BlazorBootstrap

<div class="container-fluid py-3">
    <div class="row">
        <div class="col">
            <div class="card brands-card">

                <!-- Card Header -->
                <div class="card-header bg-white border-bottom">
                    <div class="d-flex justify-content-between align-items-center py-1">
                        <div class="d-flex align-items-center flex-wrap gap-2">
                            <h5 class="mb-0">
                                <i class="bi bi-building text-primary me-2"></i>Brands
                            </h5>
                            <span class="badge bg-light text-dark ms-2">
                                <span class="text-primary fw-bold">@TotalCount</span> brands
                            </span>
                            @if (SelectedBrands.Any())
                            {
                                <span class="badge bg-primary ms-1">@SelectedBrands.Count selected</span>
                            }
                        </div>

                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            @if (SelectedBrands.Any())
                            {
                                <button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1"
                                        @onclick="BulkDelete">
                                    <i class="bi bi-trash"></i>
                                    <span class="d-none d-sm-inline">Delete (@SelectedBrands.Count)</span>
                                </button>
                            }
                            <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                    @onclick="CreateNewBrand">
                                <i class="bi bi-plus-circle"></i>
                                <span class="d-none d-sm-inline">New Brand</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Card Body -->
                <div class="card-body p-0">
                    @if (IsLoading)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="text-muted mt-3 small">Loading brands...</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover brands-table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px">
                                            <!-- ✅ Fix: bound to AllPageSelected computed property -->
                                            <input type="checkbox"
                                                   checked="@AllPageSelected"
                                                   @onchange="_ => ToggleAllSelection()" />
                                        </th>
                                        <th>Brand Name</th>
                                        <th>Code</th>
                                        <th>Slug</th>
                                        <th>Founded</th>
                                        <th>Order</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th style="width: 120px">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (PaginatedBrands.Any())
                                    {
                                        @foreach (var brand in PaginatedBrands)
                                        {
                                            var localBrand = brand; // ✅ Fix: capture loop variable
                                            <tr>
                                                <td>
                                                    <!-- ✅ Fix: use @onchange to call handler properly -->
                                                    <input type="checkbox"
                                                           checked="@localBrand.IsSelected"
                                                           @onchange="e => OnBrandSelectionChanged(localBrand, (bool)e.Value!)" />
                                                </td>
                                                <td>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="brand-avatar">
                                                            <span>@(localBrand.Name?.Length > 0 ? localBrand.Name[0].ToString() : "?")</span>
                                                        </div>
                                                        <div>
                                                            <strong>@localBrand.Name</strong>
                                                            @if (!string.IsNullOrEmpty(localBrand.Description))
                                                            {
                                                                <div class="text-muted small">@localBrand.Description</div>
                                                            }
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="badge bg-secondary">@localBrand.Code</span>
                                                </td>
                                                <td>
                                                    <code class="small">@localBrand.Slug</code>
                                                </td>
                                                <td>@(localBrand.FoundedYear?.ToString() ?? "-")</td>
                                                <td class="text-center">@localBrand.DisplayOrder</td>
                                                <td>
                                                    @if (localBrand.IsActive)
                                                    {
                                                        <span class="badge bg-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger">Inactive</span>
                                                    }
                                                </td>
                                                <td>@localBrand.CreatedAt.ToString("yyyy-MM-dd")</td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <button class="btn btn-outline-primary"
                                                                @onclick="() => EditBrand(localBrand)">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        <button class="btn btn-outline-danger"
                                                                @onclick="() => DeleteBrand(localBrand)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="9" class="text-center py-5 text-muted">
                                                No brands found
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        @if (TotalPages > 1)
                        {
                            <div class="pagination-container p-3 border-top">
                                <nav>
                                    <ul class="pagination justify-content-center mb-0">
                                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(CurrentPage - 1)">
                                                Previous
                                            </button>
                                        </li>

                                        @for (int i = 1; i <= TotalPages; i++)
                                        {
                                            var pageNum = i; // ✅ Fix: capture loop variable for closure
                                            if (pageNum == 1 || pageNum == TotalPages || (pageNum >= CurrentPage - 2 && pageNum <= CurrentPage + 2))
                                            {
                                                <li class="page-item @(CurrentPage == pageNum ? "active" : "")">
                                                    <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                                </li>
                                            }
                                            else if (pageNum == CurrentPage - 3 || pageNum == CurrentPage + 3)
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">...</span>
                                                </li>
                                            }
                                        }

                                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(CurrentPage + 1)">
                                                Next
                                            </button>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        }
                    }
                </div>

                <!-- Card Footer -->
                @if (!IsLoading && AllBrands.Any())
                {
                    <div class="card-footer bg-white border-top">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="d-flex gap-3 flex-wrap">
                                <small class="text-muted">
                                    <span class="fw-medium">@TotalCount</span> total
                                </small>
                                <small class="text-muted">
                                    <i class="bi bi-check-circle-fill text-success me-1"></i>
                                    <span class="fw-medium">@ActiveCount</span> active
                                </small>
                                <small class="text-muted">
                                    <i class="bi bi-x-circle-fill text-danger me-1"></i>
                                    <span class="fw-medium">@InactiveCount</span> inactive
                                </small>
                                <small class="text-muted">
                                    Showing @(((CurrentPage - 1) * ItemsPerPage) + 1) to
                                    @(Math.Min(CurrentPage * ItemsPerPage, TotalCount)) of @TotalCount entries
                                </small>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <small class="text-muted">Show:</small>
                                <select class="form-select form-select-sm page-size-select" @onchange="OnPageSizeChanged">
                                    @foreach (var size in PageSizeOptions)
                                    {
                                        <option value="@size" selected="@(size == ItemsPerPage)">@size</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>

    <button class="btn btn-primary mb-3" @onclick="TestLoader">
        Test Loader
    </button>
</div>