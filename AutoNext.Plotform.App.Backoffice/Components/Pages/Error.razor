@page "/error"
@using Microsoft.AspNetCore.Diagnostics

<div class="container d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="mb-4">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
        </div>
        <h2 class="fw-bold text-danger">Something went wrong</h2>
        <p class="text-muted mt-2 mb-4">
            An unexpected error occurred. Our team has been notified.<br />
            Please try again or contact support if the issue persists.
        </p>
        @if (!string.IsNullOrEmpty(TraceId))
        {
            <div class="alert alert-light border small text-muted mb-4">
                <strong>Trace ID:</strong> @TraceId
            </div>
        }
        <div class="d-flex justify-content-center gap-2">
            <a href="/" class="btn btn-primary">
                <i class="bi bi-house me-1"></i> Go Home
            </a>
            <button class="btn btn-outline-secondary" onclick="window.history.back()">
                <i class="bi bi-arrow-left me-1"></i> Go Back
            </button>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? TraceId => HttpContext?.TraceIdentifier;
}