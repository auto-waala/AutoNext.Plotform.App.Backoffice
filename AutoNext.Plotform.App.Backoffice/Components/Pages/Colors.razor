@page "/colors"
@inherits ColorsBase

<div class="container-fluid" style="padding-left: 0px; padding-right: 0px;">
    <div class="row" style="padding-left: 0px; padding-right: 0px;">
        <div class="col">
            <div class="card colors-card">
                <div class="card-header bg-white border-bottom">
                    <div class="d-flex justify-content-between align-items-center py-1">
                        <div class="d-flex align-items-center flex-wrap gap-2">
                            <h5 class="mb-0">
                                <i class="bi bi-palette text-primary me-2"></i>Colors
                            </h5>
                            <span class="badge bg-light text-dark ms-2">
                                <span class="text-primary fw-bold">@TotalCount</span> colors
                            </span>
                            @if (SelectedColors.Any())
                            {
                                <span class="badge bg-primary ms-1">@SelectedColors.Count selected</span>
                            }
                        </div>

                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            @if (SelectedColors.Any())
                            {
                                <button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1"
                                        @onclick="BulkDelete">
                                    <i class="bi bi-trash"></i>
                                    <span class="d-none d-sm-inline">Delete (@SelectedColors.Count)</span>
                                </button>
                            }
                            <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                    @onclick="OpenAddColorSidebar">
                                <i class="bi bi-plus-circle"></i>
                                <span class="d-none d-sm-inline">New Color</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Card Body -->
                <div class="card-body p-0">
                    @if (IsLoading)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="text-muted mt-3 small">Loading colors...</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover colors-table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px">
                                            <input type="checkbox"
                                                   checked="@AllPageSelected"
                                                   @onchange="_ => ToggleAllSelection()" />
                                        </th>
                                        <th>Color Name</th>
                                        <th>Code</th>
                                        <th>Color Preview</th>
                                        <th>Description</th>
                                        <th>Order</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th>Updated</th>
                                        <th style="width: 120px">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (PaginatedColors.Any())
                                    {
                                        @foreach (var color in PaginatedColors)
                                        {
                                            var localColor = color;
                                            <tr>
                                                <td>
                                                    <input type="checkbox"
                                                           checked="@SelectedColors.Contains(localColor)"
                                                           @onchange="e => OnColorSelectionChanged(localColor, (bool)e.Value!)" />
                                                </td>
                                                <td>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="color-avatar" 
                                                             style="background-color: @(localColor.HexCode ?? "#6c757d");">
                                                            <span>@(localColor.Name?.Length > 0 ? localColor.Name[0].ToString() : "?")</span>
                                                        </div>
                                                        <div>
                                                            <strong>@localColor.Name</strong>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="badge bg-secondary">@localColor.Code</span>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(localColor.HexCode))
                                                    {
                                                        <div class="d-flex align-items-center gap-2">
                                                            <div class="color-preview-lg" 
                                                                 style="background-color: @localColor.HexCode;"
                                                                 title="@localColor.HexCode"></div>
                                                            <code class="small">@localColor.HexCode</code>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-light text-dark">No Color</span>
                                                    }
                                                </td>
                                                <td class="text-truncate" style="max-width: 200px;" title="@localColor.Description">
                                                    @if (!string.IsNullOrEmpty(localColor.Description))
                                                    {
                                                        @localColor.Description
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td class="text-center">@localColor.DisplayOrder</td>
                                                <td>
                                                    @if (localColor.IsActive)
                                                    {
                                                        <span class="badge bg-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger">Inactive</span>
                                                    }
                                                </td>
                                                <td>@localColor.CreatedAt.ToString("yyyy-MM-dd")</td>
                                                <td>@(localColor.UpdatedAt?.ToString("yyyy-MM-dd") ?? "-")</td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <button class="btn btn-outline-primary"
                                                                @onclick="() => OpenEditColorSidebar(localColor)">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        <button class="btn btn-outline-danger"
                                                                @onclick="() => DeleteColor(localColor)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="10" class="text-center py-5 text-muted">
                                                No colors found
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        
                        @if (TotalPages > 1)
                        {
                            <div class="pagination-container p-3 border-top">
                                <nav>
                                    <ul class="pagination justify-content-center mb-0">
                                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(CurrentPage - 1)">
                                                Previous
                                            </button>
                                        </li>

                                        @for (int i = 1; i <= TotalPages; i++)
                                        {
                                            var pageNum = i;
                                            if (pageNum == 1 || pageNum == TotalPages || (pageNum >= CurrentPage - 2 && pageNum <= CurrentPage + 2))
                                            {
                                                <li class="page-item @(CurrentPage == pageNum ? "active" : "")">
                                                    <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                                </li>
                                            }
                                            else if (pageNum == CurrentPage - 3 || pageNum == CurrentPage + 3)
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">...</span>
                                                </li>
                                            }
                                        }

                                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(CurrentPage + 1)">
                                                Next
                                            </button>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        }
                    }
                </div>

                @if (!IsLoading && AllColors.Any())
                {
                    <div class="card-footer bg-white border-top">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="d-flex gap-3 flex-wrap">
                                <small class="text-muted">
                                    <span class="fw-medium">@TotalCount</span> total
                                </small>
                                <small class="text-muted">
                                    <i class="bi bi-check-circle-fill text-success me-1"></i>
                                    <span class="fw-medium">@ActiveCount</span> active
                                </small>
                                <small class="text-muted">
                                    <i class="bi bi-x-circle-fill text-danger me-1"></i>
                                    <span class="fw-medium">@InactiveCount</span> inactive
                                </small>
                                <small class="text-muted">
                                    Showing @(((CurrentPage - 1) * ItemsPerPage) + 1) to
                                    @(Math.Min(CurrentPage * ItemsPerPage, TotalCount)) of @TotalCount entries
                                </small>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <small class="text-muted">Show:</small>
                                <select class="form-select form-select-sm page-size-select" @onchange="OnPageSizeChanged">
                                    @foreach (var size in PageSizeOptions)
                                    {
                                        <option value="@size" selected="@(size == ItemsPerPage)">@size</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Sidebar Component -->
<ColorSidebar @bind-IsVisible="@showSidebar" ColorToEdit="@selectedColor" OnSave="@OnColorSave" />