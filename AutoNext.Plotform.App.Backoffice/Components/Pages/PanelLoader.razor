@using AutoNext.Plotform.App.Backoffice.Handlers
@inject LoaderService LoaderService
@implements IDisposable

@if (LoaderService.IsLoading)
{
    <div class="panel-loader-overlay">
        <div class="loader-container">
            <div class="big-spinner">
                <div class="spinner-ring"></div>
                <div class="spinner-center"></div>
            </div>
            <div class="loader-text">@LoaderService.Message</div>
        </div>
    </div>
}

<style>
    .panel-loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(4px);
        z-index: 999999;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .loader-container {
        text-align: center;
        max-width: 400px;
        width: 100%;
        padding: 20px;
    }

    .big-spinner {
        position: relative;
        width: 120px;
        height: 120px;
        margin: 0 auto 25px;
    }

    .spinner-ring {
        width: 100%;
        height: 100%;
        border: 12px solid rgba(0, 123, 255, 0.1);
        border-top: 12px solid #007bff;
        border-radius: 50%;
        animation: spin 1.5s linear infinite;
        box-sizing: border-box;
    }

    .spinner-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 60px;
        height: 60px;
        border: 6px solid rgba(0, 123, 255, 0.1);
        border-radius: 50%;
        background: white;
        box-sizing: border-box;
        animation: pulse 2s infinite;
    }

    @@keyframes spin {
        0%   { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    @@keyframes pulse {
        0%   { transform: translate(-50%, -50%) scale(0.9); opacity: 0.8; }
        50%  { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
        100% { transform: translate(-50%, -50%) scale(0.9); opacity: 0.8; }
    }

    .loader-text {
        font-size: 18px;
        font-weight: 600;
        color: #fff;
        margin-top: 15px;
        text-align: center;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    }
</style>

@code {
    // ✅ Store reference so we unsubscribe the exact same delegate
    private Action? _handler;

    protected override void OnInitialized()
    {
        _handler = async () => await InvokeAsync(StateHasChanged);
        LoaderService.OnChange += _handler;
    }

    public void Dispose()
    {
        // ✅ Now this actually removes the correct handler
        LoaderService.OnChange -= _handler;
    }
}